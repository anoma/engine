# Testing the Formal Message Passing Mechanism (Mailbox-as-Actors)

```elixir
Mix.install([
  {:engine_system, path: "."}
])
```

## Introduction

This notebook demonstrates the **formal message passing mechanism** from the Engine Model paper, specifically the **mailbox-as-actors** architecture. This is the core innovation of the paper:

1. **Processing engines** don't receive messages directly
2. **Mailbox engines** are first-class actors that intercept and store messages
3. **Formal routing**: The system automatically routes messages to mailbox engines
4. **Controlled delivery**: Processing engines pull messages when ready

The formal rules implemented are:
- **m-Send**: Route messages to mailbox engines automatically
- **m-Enqueue**: Mailbox engines store incoming messages
- **m-Dequeue**: Processing engines pull messages from their mailboxes

## Setup and Basic Testing

```elixir
# Start the application
{:ok, _} = Application.ensure_all_started(:engine_system)

# Allow some time for system services to start
Process.sleep(100)

# Check that the router is running
{:ok, router_stats} = EngineSystem.MessagePassing.Router.get_stats()
IO.puts("Router started - Stats: #{inspect(router_stats)}")
```

## Define a Simple Key-Value Store Engine

Let's create a key-value store engine that follows the formal model:

```elixir
defmodule KeyValueStore do
  @moduledoc """
  A simple key-value store engine that demonstrates the formal model.
  
  According to the paper, I process messages through guarded actions and
  maintain local state (the store).
  """
  
  use EngineSystem.Engine.Behaviour
  
  # Define message interface
  defmessage {:put, key :: String.t(), value :: any()}
  defmessage {:get, key :: String.t()}
  defmessage {:delete, key :: String.t()}
  defmessage {:size}
  
  # Define environment (local state)
  defenv store: %{}, access_count: %{}
  
  # Define configuration
  defconfig read_only: false
  
  # Guarded actions (behaviour)
  defguard put_guard do
    message({:put, key, value}) when not config().read_only ->
      {:ok, {key, value}}
  end
  
  defaction put_action do
    {key, value} ->
      new_store = Map.put(env().store, key, value)
      new_count = Map.update(env().access_count, key, 1, &(&1 + 1))
      
      effects([
        update_env(store: new_store, access_count: new_count),
        send(message().sender, {:ok, :stored})
      ])
  end
  
  defguard get_guard do
    message({:get, key}) ->
      {:ok, key}
  end
  
  defaction get_action do
    key ->
      value = Map.get(env().store, key)
      new_count = Map.update(env().access_count, key, 1, &(&1 + 1))
      
      effects([
        update_env(access_count: new_count),
        send(message().sender, {:result, value})
      ])
  end
  
  defguard delete_guard do
    message({:delete, key}) when not config().read_only ->
      {:ok, key}
  end
  
  defaction delete_action do
    key ->
      new_store = Map.delete(env().store, key)
      
      effects([
        update_env(store: new_store),
        send(message().sender, {:ok, :deleted})
      ])
  end
  
  defguard size_guard do
    message({:size}) ->
      {:ok, :size}
  end
  
  defaction size_action do
    :size ->
      size = map_size(env().store)
      access_total = env().access_count |> Map.values() |> Enum.sum()
      
      effects([
        send(message().sender, {:stats, size, access_total})
      ])
  end
end
```

## Register and Test the Key-Value Store Engine

```elixir
# Compile and register the engine type
{:ok, _type_info} = EngineSystem.System.Toolchain.register_engine_type_from_module(
  KeyValueStore,
  "1.0.0"
)

IO.puts("Key-Value Store engine type registered")

# Create an engine instance using the NEW processing engine architecture
config = %{read_only: false}

case EngineSystem.System.Services.create_engine_instance({"KeyValueStore", "1.0.0"}, config) do
  %EngineSystem.Types.OperationResult{status: :ok, value: kv_address} ->
    IO.puts("Key-Value Store engine created at address: #{inspect(kv_address)}")
    
    # Store the address for later use
    Process.put(:kv_address, kv_address)
    
  error ->
    IO.puts("Failed to create engine: #{inspect(error)}")
end

kv_address = Process.get(:kv_address)
```

## Test the Formal Message Passing Mechanism

Now let's test the formal message passing rules:

### 1. Test m-Send Rule (Automatic Routing to Mailbox)

```elixir
kv_address = Process.get(:kv_address)

# When we send a message to the processing engine,
# it should be automatically routed to its mailbox engine
IO.puts("Testing m-Send rule: Sending messages to processing engine...")

# Send PUT messages - these will be routed to the mailbox automatically
result1 = EngineSystem.System.Services.send_message(kv_address, {:put, "name", "Alice"})
result2 = EngineSystem.System.Services.send_message(kv_address, {:put, "age", 30})
result3 = EngineSystem.System.Services.send_message(kv_address, {:put, "city", "Paris"})

IO.puts("PUT messages sent:")
IO.puts("  - Result 1: #{inspect(result1)}")
IO.puts("  - Result 2: #{inspect(result2)}")  
IO.puts("  - Result 3: #{inspect(result3)}")

# Allow processing time
Process.sleep(100)
```

### 2. Test m-Enqueue and m-Dequeue Rules

```elixir
kv_address = Process.get(:kv_address)

IO.puts("Testing m-Enqueue and m-Dequeue rules...")

# Send GET messages to test retrieval
get_result1 = EngineSystem.System.Services.send_message(kv_address, {:get, "name"})
get_result2 = EngineSystem.System.Services.send_message(kv_address, {:get, "age"})
get_result3 = EngineSystem.System.Services.send_message(kv_address, {:get, "nonexistent"})

IO.puts("GET messages sent:")
IO.puts("  - Get name: #{inspect(get_result1)}")
IO.puts("  - Get age: #{inspect(get_result2)}")
IO.puts("  - Get nonexistent: #{inspect(get_result3)}")

# Get statistics
stats_result = EngineSystem.System.Services.send_message(kv_address, {:size})
IO.puts("  - Stats request: #{inspect(stats_result)}")

# Allow processing time
Process.sleep(200)
```

### 3. Test Mailbox Policy - Different Delivery Strategies

Now let's test different mailbox delivery policies:

```elixir
# Create engines with different mailbox policies
IO.puts("Testing different mailbox delivery policies...")

# FIFO (default) - already tested above
IO.puts("FIFO policy tested with main engine")

# Priority-based policy engine
case EngineSystem.Engine.ProcessingEngine.start_link(
  "KeyValueStore", 
  "1.0.0", 
  %{read_only: false}, 
  :priority  # Priority-based mailbox
) do
  {:ok, {priority_pid, _mailbox_pid}} ->
    IO.puts("Priority-based mailbox engine started")
    
    # Get the address
    case EngineSystem.Engine.ProcessingEngine.get_info(priority_pid) do
      %{status: :ok, value: info} ->
        priority_address = info.address
        Process.put(:priority_address, priority_address)
        IO.puts("   Address: #{inspect(priority_address)}")
        
      error ->
        IO.puts("Failed to get priority engine info: #{inspect(error)}")
    end
    
  error ->
    IO.puts("Failed to create priority engine: #{inspect(error)}")
end

# Key-based policy engine  
case EngineSystem.Engine.ProcessingEngine.start_link(
  "KeyValueStore", 
  "1.0.0", 
  %{read_only: false}, 
  :key_based  # Key-based mailbox
) do
  {:ok, {key_pid, _mailbox_pid}} ->
    IO.puts("Key-based mailbox engine started")
    
    # Get the address
    case EngineSystem.Engine.ProcessingEngine.get_info(key_pid) do
      %{status: :ok, value: info} ->
        key_address = info.address
        Process.put(:key_address, key_address)
        IO.puts("   Address: #{inspect(key_address)}")
        
      error ->
        IO.puts("Failed to get key-based engine info: #{inspect(error)}")
    end
    
  error ->
    IO.puts("Failed to create key-based engine: #{inspect(error)}")
end
```

