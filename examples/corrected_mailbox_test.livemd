if kv_address do
  case EngineSystem.MessagePassing.Router.get_mailbox_address(kv_address) do
    {:ok, mailbox_address} ->
      IO.puts("📮 Main KV Engine Mailbox: #{inspect(mailbox_address)}")
      
    error ->
      IO.puts("❌ Failed to get mailbox address: #{inspect(error)}")
  end
end
```

